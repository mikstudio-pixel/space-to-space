# Cloudflare account identifier used in the R2 endpoint URL
CLOUDFLARE_ACCOUNT_ID=your_account_id

# R2 API token credentials (S3-compatible), not the generic dashboard bearer token
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Target bucket name
R2_BUCKET_NAME=your_bucket_name

# Optional prefix inside the bucket, for example "assets"
R2_UPLOAD_PREFIX=

# Optional explicit endpoint override
# R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
